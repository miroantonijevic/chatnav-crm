# Project Configuration
PROJECT_NAME=CRM Application
API_V1_PREFIX=/api/v1

# CORS - comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/crm.db

# Security - CHANGE THIS IN PRODUCTION!
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin Bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=System Admin

# SMTP Configuration (Zoho)
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=587
SMTP_USERNAME=your-zoho-email@yourdomain.com
SMTP_PASSWORD=your-zoho-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_START_TLS=true

# Reminders
REMINDERS_ENABLED=true
REMINDER_CHECK_INTERVAL_MINUTES=60
